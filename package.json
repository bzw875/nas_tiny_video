{
  "name": "autopushold",
  "version": "1.0.0",
  "private": true,
  "description": "Video manager monorepo",
  "license": "ISC",
  "dependencies": {
    "mysql2": "^3.14.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "run": "node scan-videos.js",
    "import": "node import-videos.js",
    "dev:api": "npm run start:dev -w @video-manager/api",
    "dev:web": "npm run dev -w @video-manager/web",
    "build:api": "npm run build -w @video-manager/api",
    "build:web": "npm run build -w @video-manager/web",
    "prisma:generate": "npm run prisma:generate -w @video-manager/api"
  }
}
