# 方式一：连接串（密码勿提交到 Git，仅放在本机 .env）
# DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/video_manager"

# 方式二：分项配置（未设置 DATABASE_URL 时自动拼成连接串；推荐把密码只写在 DB_PASSWORD）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=
DB_NAME=video_manager

PORT=4000
# 可选：多个来源用逗号分隔，例如 http://localhost:5173
# CORS_ORIGIN=http://localhost:5173

# 小说 TXT 目录（可选）
# NOVEL_TXT_DIR=./txt
